SERVER_PORT=5000
SERVER_NAME=My Discard Server
SERVER_DESCRIPTION=A locally-hosted Discard community
IS_PUBLIC=false

# JWT secret must match the relay server
JWT_SECRET=change_this_to_a_long_random_secret

# Relay discovery server URL
RELAY_URL=http://localhost:4000

# Your personal JWT token from the relay (run: node scripts/get-token.js)
SERVER_OWNER_TOKEN=

# Where to store the sqlite database
SERVER_DB_PATH=./server.db

# ─── WebRTC / Voice ───────────────────────────────────────────────────────────
# IMPORTANT: PUBLIC_ADDRESS must be a plain IPv4 address, NOT a hostname such
# as "localhost".  Chromium (used in the desktop client) resolves "localhost" to
# ::1 (IPv6) while mediasoup only binds on IPv4, causing ICE to fail silently
# and voice chat to produce no audio.
#
# Local testing  → 127.0.0.1
# LAN hosting    → your machine's LAN IP  (e.g. 192.168.1.100)
# Public hosting → your public IPv4 address  (e.g. 203.0.113.42)
MEDIASOUP_LISTEN_IP=0.0.0.0
PUBLIC_ADDRESS=127.0.0.1
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999
MEDIASOUP_LOG_LEVEL=warn
# Server-side initial audio bitrate cap in kbps (clients can override per-session, 8–512; Opus useful range is 32–320)
AUDIO_BITRATE_KBPS=64

# ─── UPnP / NAT port mapping ─────────────────────────────────────────────────
# Automatically forward ports on the router at startup (requires UPnP/IGD).
# If UPnP is unavailable the server starts normally without error.
UPNP_ENABLED=true
# Lease duration in seconds; 0 = indefinite (recommended for home servers)
UPNP_TTL=0
# Maximum number of RTC UDP ports to map via UPnP.
# If the RTC range above is larger than this, it is automatically clamped to
# this many ports (starting from RTC_MIN_PORT) and mediasoup is started with
# the same narrowed range, keeping forwarding and media in sync.
# 50 ports is ample for a small home server (each voice session uses ~2 ports).
UPNP_RTC_MAX_PORTS=50
