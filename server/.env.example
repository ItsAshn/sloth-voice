SERVER_PORT=5000
SERVER_NAME=My Discard Server
SERVER_DESCRIPTION=A locally-hosted Discard community
PUBLIC_ADDRESS=localhost
IS_PUBLIC=false

# JWT secret must match the relay server
JWT_SECRET=change_this_to_a_long_random_secret

# Relay discovery server URL
RELAY_URL=http://localhost:4000

# Your personal JWT token from the relay (run: node scripts/get-token.js)
SERVER_OWNER_TOKEN=

# Where to store the sqlite database
SERVER_DB_PATH=./server.db

# mediasoup settings
MEDIASOUP_LISTEN_IP=127.0.0.1
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999
MEDIASOUP_LOG_LEVEL=warn
