# ═══════════════════════════════════════════════════════════════════════════════
#  Sloth Voice Server — configuration
#
#  Copy this file to .env and fill in the values marked  ← REQUIRED
#  Everything else has a sensible default and can be left as-is to get started.
#
#  Generate a secure JWT_SECRET with one of:
#    Linux/macOS  →  openssl rand -hex 64
#    Node.js      →  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ═══════════════════════════════════════════════════════════════════════════════

# ─── General ──────────────────────────────────────────────────────────────────

# Port the HTTP server and WebSocket listen on.
# If you change this, update firewall rules and port-forward rules to match.
SERVER_PORT=5000

# Display name shown to clients in the server browser.
SERVER_NAME=My Sloth Voice Server

# Short description shown to clients in the server browser.
SERVER_DESCRIPTION=A locally-hosted Sloth Voice community

# Optional join password. Anyone trying to register an account on this server
# must supply this password. Leave blank to allow anyone to join freely.
SERVER_PASSWORD=

# ─── Security  ────────────────────────────────────────────────────────────────

# ← REQUIRED — Secret used to sign and verify authentication tokens.
# Must be a long, random string. Never share it or commit it to version control.
# Changing this value will invalidate all existing user sessions.
JWT_SECRET=change_this_to_a_long_random_secret

# ─── Database ─────────────────────────────────────────────────────────────────

# Path where the SQLite database file is stored.
# When running with Docker, this is automatically set to /data/server.db inside
# the container, which is backed by a persistent volume — do not change it there.
SERVER_DB_PATH=./server.db

# ─── WebRTC / Voice ───────────────────────────────────────────────────────────

# IP that mediasoup binds to internally. Keep 0.0.0.0 to listen on all
# network interfaces (correct for virtually every setup).
MEDIASOUP_LISTEN_IP=0.0.0.0

# Your server's public address used as the WebRTC ICE candidate for voice.
#
# Three modes are supported — pick whichever matches your setup:
#
#   1. Static IPv4  (VPS / server with a fixed IP)
#      Set this to your bare dotted-decimal IPv4.  The value is used as-is
#      and no background polling is started.
#        PUBLIC_ADDRESS=203.0.113.42
#
#   2. DDNS hostname  (home hosting with a DDNS client running)
#      Set this to your DDNS hostname.  At startup the server resolves it to
#      an IPv4 and then re-resolves it every IP_CHECK_INTERVAL seconds so the
#      ICE candidate stays accurate after your DDNS record updates.
#        PUBLIC_ADDRESS=yourserver.duckdns.org
#
#   3. Fully automatic  (blank — recommended for first-time / casual hosting)
#      Leave blank.  The server tries UPnP first (to get the gateway's
#      external IP), then falls back to querying public IP-echo services
#      (api.ipify.org, icanhazip.com, …).  The watcher re-queries them
#      periodically so a new ISP assignment is detected automatically.
#        PUBLIC_ADDRESS=
#
# ⚠  The final resolved value MUST be a bare dotted-decimal IPv4.
#    The Sloth Voice desktop client runs on Chromium, which resolves names to
#    ::1 (IPv6).  mediasoup only binds IPv4, so sending a hostname as the
#    ICE candidate causes voice to fail silently — the module handles this
#    by always converting any hostname to IPv4 before passing it on.
PUBLIC_ADDRESS=

# UDP port range reserved for WebRTC voice sessions.
# Each active voice participant uses roughly 2 ports.
# The range below (100 ports) comfortably supports ~50 concurrent voice users.
# These ports must be open in your firewall and (if applicable) forwarded on
# your router — see the README for details.
RTC_MIN_PORT=40000
RTC_MAX_PORT=40099
# How often (in seconds) to re-check the public IP for changes.
# Relevant for DDNS and auto-detect modes; ignored for static IPv4.
# Lower values mean faster failover but more DNS / API traffic.
# 300 (5 minutes) is a sensible default.
IP_CHECK_INTERVAL=300
# mediasoup internal log verbosity. Options: debug | warn | error | none
# Leave as "warn" unless you are troubleshooting voice issues.
MEDIASOUP_LOG_LEVEL=warn

# Maximum audio bitrate cap in kbps applied server-side to voice channels.
# Clients may negotiate a lower value per session.
# Opus useful range: 32 (low quality) – 320 (high quality). 64 is a good default.
AUDIO_BITRATE_KBPS=64

# ─── UPnP / NAT port mapping ──────────────────────────────────────────────────
# When enabled, the server asks your router to forward the required ports
# automatically at startup using UPnP/IGD. If your router does not support
# UPnP, or UPnP is disabled, the server starts normally without error — you
# will just need to forward ports manually.
#
# Recommended: leave enabled for home/residential hosting. Disable if you are
# on a VPS or dedicated server where you manage firewall rules yourself.
UPNP_ENABLED=true

# How long (in seconds) the UPnP port-forward lease lasts before it expires.
# 0 = indefinite (the router keeps the mapping until the server removes it or
# is restarted). Indefinite is recommended so voice does not drop unexpectedly.
UPNP_TTL=0

# Maximum number of RTC UDP ports to map via UPnP. If RTC_MAX_PORT − RTC_MIN_PORT
# is larger than this, the range is narrowed automatically and mediasoup is
# started with the same narrowed range so forwarding and media stay in sync.
# 50 ports supports ~25 concurrent voice users and is fine for most communities.
UPNP_RTC_MAX_PORTS=50

