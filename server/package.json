{
  "name": "sloth-voice-server",
  "version": "0.8.7",
  "description": "Locally-hosted Sloth Voice server — run this on your machine to host a community",
  "main": "src/index.js",
  "scripts": {
    "start": "node --experimental-sqlite src/index.js",
    "dev": "nodemon --exec \"node --experimental-sqlite\" src/index.js",
    "setup": "node --experimental-sqlite src/setup.js",
    "doctor": "node --experimental-sqlite src/doctor.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.14.8",
    "nat-upnp": "^1.1.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
