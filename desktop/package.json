{
  "name": "sloth-voice-desktop",
  "version": "0.11.0",
  "description": "Sloth Voice desktop client",
  "type": "module",
  "main": "out/main/index.cjs",
  "asar": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "axios": "^1.6.8",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "mediasoup-client": "^3.18.6",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "socket.io-client": "^4.7.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2"
  },
  "build": {
    "appId": "com.slothvoice.desktop",
    "productName": "Sloth Voice",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "ItsAshn",
      "repo": "sloth-voice"
    },
    "win": {
      "target": "nsis",
      "sign": null,
      "artifactName": "Sloth-Voice-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "identity": null,
      "artifactName": "Sloth-Voice-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "Sloth-Voice-${version}.${ext}"
    }
  }
}
